\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces Static mask derivation on a DexYCB frame. (a) i) The raw frame-wise pixel-difference prior flags regions of substantial change between consecutive frames, but produces a fragmented signal with noise and holes within the moving subject. (a) ii) SAM2~\blx@tocontentsinit {0}\cite {sam2} propagates this prior into a coherent segmentation covering the full extent of the hand and object, including textureless regions that the raw difference signal alone fails to capture. (b) Farnebäck optical flow~\blx@tocontentsinit {0}\cite {farneback2003two} produces a similarly fragmented mask, motivating the use of the simpler pixel-difference prior refined by SAM2 rather than a dedicated optical flow estimator. Black denotes dynamic pixels excluded from static correspondences.}}{15}{figure.caption.5}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:static_mask_derivation}{{3.1}{15}{Static mask derivation on a DexYCB frame. (a) i) The raw frame-wise pixel-difference prior flags regions of substantial change between consecutive frames, but produces a fragmented signal with noise and holes within the moving subject. (a) ii) SAM2~\cite {sam2} propagates this prior into a coherent segmentation covering the full extent of the hand and object, including textureless regions that the raw difference signal alone fails to capture. (b) Farnebäck optical flow~\cite {farneback2003two} produces a similarly fragmented mask, motivating the use of the simpler pixel-difference prior refined by SAM2 rather than a dedicated optical flow estimator. Black denotes dynamic pixels excluded from static correspondences}{figure.caption.5}{}}
\newlabel{fig:static_mask_derivation@cref}{{[figure][1][3]3.1}{[1][14][]15}{}{}{}}
\@writefile{toc}{\contentsline {subsubsection}{Strategy 1: Reference Frame}{15}{figure.caption.6}\protected@file@percent }
\newlabel{sec:strategy1}{{3.1.2}{15}{Strategy 1: Reference Frame}{figure.caption.6}{}}
\newlabel{sec:strategy1@cref}{{[subsection][2][3,1]3.1.2}{[1][14][]15}{}{}{}}
\@writefile{toc}{\contentsline {subsubsection}{Strategy 2: Hierarchical Alignment}{15}{figure.caption.6}\protected@file@percent }
\newlabel{sec:strategy2}{{3.1.2}{15}{Strategy 2: Hierarchical Alignment}{figure.caption.6}{}}
\newlabel{sec:strategy2@cref}{{[subsection][2][3,1]3.1.2}{[1][15][]15}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces The three temporal alignment strategies. (a) Strategy 1: Reference Frame. Every frame $t_i$ is aligned directly to the reference frame $t_0$. (b) Strategy 2: Hierarchical Alignment. Frames are merged pairwise in a binary tree, with each level combining adjacent pairs until all frames share a single coordinate system. (c) Strategy 3: Alignment Graph. All $\mathcal  {O}(T^2)$ pairwise alignments are estimated and combined through iterative geodesic averaging; edge thickness indicates alignment reliability, with high-weight edges (thick blue) contributing more to the global solution than low-weight edges (thin blue).}}{16}{figure.caption.6}\protected@file@percent }
\newlabel{fig:strategies}{{3.2}{16}{The three temporal alignment strategies. (a) Strategy 1: Reference Frame. Every frame $t_i$ is aligned directly to the reference frame $t_0$. (b) Strategy 2: Hierarchical Alignment. Frames are merged pairwise in a binary tree, with each level combining adjacent pairs until all frames share a single coordinate system. (c) Strategy 3: Alignment Graph. All $\mathcal {O}(T^2)$ pairwise alignments are estimated and combined through iterative geodesic averaging; edge thickness indicates alignment reliability, with high-weight edges (thick blue) contributing more to the global solution than low-weight edges (thin blue)}{figure.caption.6}{}}
\newlabel{fig:strategies@cref}{{[figure][2][3]3.2}{[1][14][]16}{}{}{}}
\@writefile{toc}{\contentsline {subsubsection}{Strategy 3: Alignment Graph Optimisation}{16}{figure.caption.6}\protected@file@percent }
\newlabel{sec:strategy3}{{3.1.2}{16}{Strategy 3: Alignment Graph Optimisation}{figure.caption.6}{}}
\newlabel{sec:strategy3@cref}{{[subsection][2][3,1]3.1.2}{[1][15][]16}{}{}{}}
