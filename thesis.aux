\@writefile{lof}{\contentsline {figure}{\numberline {5.1}{\ignorespaces Geometry vs.\ temporal consistency trade-off on DexYCB, pooled over view counts. Each point represents one model--method combination plotted on logarithmic axes. Opt-smoothed spatial models (blue stars) cluster in the lower-left quadrant, achieving both low Chamfer distance and low mean jitter simultaneously. GGPT points lie to the right of all spatial model configurations, reflecting substantial Chamfer increases. Native 4D architectures reduce jitter relative to unsmoothed spatial models but at substantially higher Chamfer. The lower-left corner represents the optimal operating region.}}{37}{figure.caption.15}\protected@file@percent }
\newlabel{fig:pareto}{{5.1}{37}{Geometry vs.\ temporal consistency trade-off on DexYCB, pooled over view counts. Each point represents one model--method combination plotted on logarithmic axes. Opt-smoothed spatial models (blue stars) cluster in the lower-left quadrant, achieving both low Chamfer distance and low mean jitter simultaneously. GGPT points lie to the right of all spatial model configurations, reflecting substantial Chamfer increases. Native 4D architectures reduce jitter relative to unsmoothed spatial models but at substantially higher Chamfer. The lower-left corner represents the optimal operating region}{figure.caption.15}{}}
\newlabel{fig:pareto@cref}{{[figure][1][5]5.1}{[1][36][]37}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.1}{\ignorespaces Per-frame geometric performance averaged over 2, 3, and 4 views on DexYCB and Hi4D. Each frame is aligned independently to ground truth; no temporal alignment is applied. Accuracy and completeness are reported as percentages at a 1\,cm threshold. Static/dynamic decomposition is reported for DexYCB only; Hi4D provides no static background so all evaluated points are dynamic. \textbf  {Bold} = best per column within dataset, \underline  {underline} = second best.}}{38}{table.caption.12}\protected@file@percent }
\newlabel{tab:baseline_control_ggpt}{{5.1}{38}{Per-frame geometric performance averaged over 2, 3, and 4 views on DexYCB and Hi4D. Each frame is aligned independently to ground truth; no temporal alignment is applied. Accuracy and completeness are reported as percentages at a 1\,cm threshold. Static/dynamic decomposition is reported for DexYCB only; Hi4D provides no static background so all evaluated points are dynamic. \textbf {Bold} = best per column within dataset, \underline {underline} = second best}{table.caption.12}{}}
\newlabel{tab:baseline_control_ggpt@cref}{{[table][1][5]5.1}{[1][31][]38}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.2}{\ignorespaces Alignment strategy comparison on DexYCB and Hi4D, pooled over view counts. $\Delta _{\text  {consistency}}$ measures the increase in Chamfer distance introduced by temporal alignment relative to independent per-frame ground-truth registration; a value near zero indicates that alignment preserves per-frame geometry faithfully. ATE, RPE, and rotation error serve as additional indicators of alignment quality, since the same transformations computed for the point clouds are applied to the cameras. \textbf  {Bold} = best within each strategy block or GGPT block.}}{39}{table.caption.13}\protected@file@percent }
\newlabel{tab:strategy_extended}{{5.2}{39}{Alignment strategy comparison on DexYCB and Hi4D, pooled over view counts. $\Delta _{\text {consistency}}$ measures the increase in Chamfer distance introduced by temporal alignment relative to independent per-frame ground-truth registration; a value near zero indicates that alignment preserves per-frame geometry faithfully. ATE, RPE, and rotation error serve as additional indicators of alignment quality, since the same transformations computed for the point clouds are applied to the cameras. \textbf {Bold} = best within each strategy block or GGPT block}{table.caption.13}{}}
\newlabel{tab:strategy_extended@cref}{{[table][2][5]5.2}{[1][32][]39}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.3}{\ignorespaces Per-view-count spatio-temporal performance on DexYCB. Each block reports results for a fixed number of input views (2, 3, or 4). Accuracy and completeness are evaluated at a 1\,cm threshold and decomposed into static and dynamic scene regions (reported as percentages). Temporal metrics---jitter mean, high-frequency (HF) jitter, and drift---are computed on static scene anchors. Strategy 2 serves as the unsmoothed temporal alignment baseline for spatial models. +Opt applies the proposed Gaussian-weighted temporal smoothing. GGPT\,(S2) and GGPT\,(N4D) apply geometry-grounded point transformer refinement to Strategy 2 and native 4D model outputs, respectively. \textbf  {Bold} = best per column within each view-count block, \underline  {underline} = second best.}}{40}{table.caption.14}\protected@file@percent }
\newlabel{tab:global_performance_dex_ycb}{{5.3}{40}{Per-view-count spatio-temporal performance on DexYCB. Each block reports results for a fixed number of input views (2, 3, or 4). Accuracy and completeness are evaluated at a 1\,cm threshold and decomposed into static and dynamic scene regions (reported as percentages). Temporal metrics---jitter mean, high-frequency (HF) jitter, and drift---are computed on static scene anchors. Strategy 2 serves as the unsmoothed temporal alignment baseline for spatial models. +Opt applies the proposed Gaussian-weighted temporal smoothing. GGPT\,(S2) and GGPT\,(N4D) apply geometry-grounded point transformer refinement to Strategy 2 and native 4D model outputs, respectively. \textbf {Bold} = best per column within each view-count block, \underline {underline} = second best}{table.caption.14}{}}
\newlabel{tab:global_performance_dex_ycb@cref}{{[table][3][5]5.3}{[1][33][]40}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Pipeline progression on DexYCB at 2 views for the four spatial models. Left panel: mean jitter at each pipeline stage (Baseline, Strategy 2, Opt). Right panel: corresponding Chamfer distance. \textit  {Baseline} denotes per-frame aligned output with no temporal alignment applied. Horizontal reference lines mark VGGT4D (dashed teal), MonoFusion (dot-dash brown), and GGPT\,(VGGT) (dotted purple) as fixed baselines.}}{41}{figure.caption.16}\protected@file@percent }
\newlabel{fig:pipeline_progression}{{5.2}{41}{Pipeline progression on DexYCB at 2 views for the four spatial models. Left panel: mean jitter at each pipeline stage (Baseline, Strategy 2, Opt). Right panel: corresponding Chamfer distance. \textit {Baseline} denotes per-frame aligned output with no temporal alignment applied. Horizontal reference lines mark VGGT4D (dashed teal), MonoFusion (dot-dash brown), and GGPT\,(VGGT) (dotted purple) as fixed baselines}{figure.caption.16}{}}
\newlabel{fig:pipeline_progression@cref}{{[figure][2][5]5.2}{[1][36][]41}{}{}{}}
