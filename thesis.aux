\@writefile{lof}{\contentsline {figure}{\numberline {5.3}{\ignorespaces VGGT4D reconstruction on DexYCB at 2, 3, and 4 views from the same viewpoint. At 2 views~(a), the arm region is diffuse and incomplete. At 3 views~(b), a duplicated arm appears at a second depth layer, visible as increased point density toward the right. At 4 views~(c), the arm collapses into a sweeping curved smear, visually worse than 3 views, directly supporting the non-monotonic completeness pattern of Section~\ref {sec:sparse_view}.}}{45}{figure.caption.17}\protected@file@percent }
\newlabel{fig:vggt4d_smearing}{{5.3}{45}{VGGT4D reconstruction on DexYCB at 2, 3, and 4 views from the same viewpoint. At 2 views~(a), the arm region is diffuse and incomplete. At 3 views~(b), a duplicated arm appears at a second depth layer, visible as increased point density toward the right. At 4 views~(c), the arm collapses into a sweeping curved smear, visually worse than 3 views, directly supporting the non-monotonic completeness pattern of Section~\ref {sec:sparse_view}}{figure.caption.17}{}}
\newlabel{fig:vggt4d_smearing@cref}{{[figure][3][5]5.3}{[1][44][]45}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces MonoFusion reconstruction on Hi4D at 2 views (blue). The ground truth shows two upright interacting subjects. MonoFusion produces two spatially separated, horizontally collapsed copies of the subject pair rather than a single coherent reconstruction. GGPT is not applied on Hi4D because the duplicated output is an unreliable refinement input.}}{45}{figure.caption.18}\protected@file@percent }
\newlabel{fig:monofusion_duplicate}{{5.4}{45}{MonoFusion reconstruction on Hi4D at 2 views (blue). The ground truth shows two upright interacting subjects. MonoFusion produces two spatially separated, horizontally collapsed copies of the subject pair rather than a single coherent reconstruction. GGPT is not applied on Hi4D because the duplicated output is an unreliable refinement input}{figure.caption.18}{}}
\newlabel{fig:monofusion_duplicate@cref}{{[figure][4][5]5.4}{[1][44][]45}{}{}{}}
