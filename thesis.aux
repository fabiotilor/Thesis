\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Metric profiles for PI3 as a function of $\sigma $ for each value of $\alpha $, averaged over all subjects and view counts. Increasing $\sigma $ reduces mean jitter monotonically but raises Chamfer distance and lowers accuracy, with higher $\alpha $ amplifying both effects. The red circle marks the selected operating point $\sigma = 4$, $\alpha = 1.0$, chosen where jitter reduction is substantial but geometric degradation remains limited.}}{19}{figure.caption.7}\protected@file@percent }
\newlabel{fig:metric_profiles}{{3.3}{19}{Metric profiles for PI3 as a function of $\sigma $ for each value of $\alpha $, averaged over all subjects and view counts. Increasing $\sigma $ reduces mean jitter monotonically but raises Chamfer distance and lowers accuracy, with higher $\alpha $ amplifying both effects. The red circle marks the selected operating point $\sigma = 4$, $\alpha = 1.0$, chosen where jitter reduction is substantial but geometric degradation remains limited}{figure.caption.7}{}}
\newlabel{fig:metric_profiles@cref}{{[figure][3][3]3.3}{[1][18][]19}{}{}{}}
